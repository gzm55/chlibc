{
  "version": 10,
  "$comment": "$comment requires version 10",
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "common",
      "hidden": true,
      "description": "common configurations",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "${sourceDir}/cmake/toolchain/${presetName}.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_PROJECT_TOP_LEVEL_INCLUDES": "${sourceDir}/cmake/top-include.cmake"
      },
      "environment": {
        "LC_ALL": "C",
        "TZ": "UTC"
      }
    },
    {
      "name": "conda-build",
      "description": "conda-build configurations",
      "inherits": "common",
      "generator": "Ninja"
    },
    {
      "name": "base",
      "hidden": true,
      "description": "base configurations for pixi run",
      "inherits": "common",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release"
      }
    },
    {
      "name": "clang-x86_64",
      "displayName": "Linux Cross-Compile for ${presetName}",
      "description": "Using Ninja Multi-Config with ${presetName} linux toolchain",
      "inherits": "base"
    },
    {
      "name": "clang-aarch64",
      "displayName": "Linux Cross-Compile for ${presetName}",
      "description": "Using Ninja Multi-Config with ${presetName} linux toolchain",
      "inherits": "base"
    },
    {
      "name": "clang-riscv64",
      "displayName": "Linux Cross-Compile for ${presetName}",
      "description": "Using Ninja Multi-Config with ${presetName} linux toolchain",
      "inherits": "base"
    },
    {
      "name": "gcc-x86_64",
      "displayName": "Linux Cross-Compile for ${presetName}",
      "description": "Using Ninja Multi-Config with ${presetName} linux toolchain",
      "inherits": "base",
      "$comment": "now only for checking the compatibility of gcc"
    }
  ],
  "buildPresets": [
    {
      "name": "conda-build",
      "configurePreset": "conda-build",
      "cleanFirst": true
    },
    {
      "name": "clang-x86_64-debug",
      "configurePreset": "clang-x86_64",
      "configuration": "Debug"
    },
    {
      "name": "clang-x86_64-release",
      "configurePreset": "clang-x86_64",
      "configuration": "Release"
    },
    {
      "name": "clang-aarch64-debug",
      "configurePreset": "clang-aarch64",
      "configuration": "Debug"
    },
    {
      "name": "clang-aarch64-release",
      "configurePreset": "clang-aarch64",
      "configuration": "Release"
    },
    {
      "name": "clang-riscv64-debug",
      "configurePreset": "clang-riscv64",
      "configuration": "Debug"
    },
    {
      "name": "clang-riscv64-release",
      "configurePreset": "clang-riscv64",
      "configuration": "Release"
    },
    {
      "name": "gcc-x86_64-release",
      "configurePreset": "gcc-x86_64",
      "configuration": "Release"
    }
  ]
}
